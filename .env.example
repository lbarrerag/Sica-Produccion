# Base de datos PostgreSQL
# Local: postgresql://postgres:postgres@localhost:5432/sica
# Azure: postgresql://usuario:password@servidor.postgres.database.azure.com:5432/sica?sslmode=require
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/sica"

# URL base de la aplicación
NEXTAUTH_URL="http://localhost:3000"

# Secret para firmar JWT — genera uno con: openssl rand -base64 32
NEXTAUTH_SECRET="cambia-esto-por-un-secret-seguro"

# (Opcional) URL pública en producción
# NEXT_PUBLIC_APP_URL="https://sica.azurewebsites.net"
